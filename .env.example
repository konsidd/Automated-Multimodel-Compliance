# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=AMC
# OpenAI-compatible (optional – leave blank if using Ollama)
OPENAI_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
 
# Tell pytesseract where Tesseract is installed on Windows
TESSDATA_PREFIX=D:\Tools\Tesseract\tessdata